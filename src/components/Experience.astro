---
const cv = await import("../../public/cv-es.json");
const experience = cv.experience;
console.log(experience);
---

<section class="relative flex flex-col justify-center">
  <div class="w-full max-w-6xl mx-auto px-4 md:px-6 py-24">
    <div class="flex flex-col justify-center divide-y divide-slate-100 [&>*]:py-16">
      <div class="w-full max-w-3xl mx-auto">
        <div class="-my-6">
          {
            experience.map((i) => (
              <div class="relative pl-8 sm:pl-32 py-6 group ">
                <p class="inline-flex text-white opacity-50 text-xs ">{i.time}</p>
                <div class="flex flex-col  items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-0 before:h-full before:px-px before:bg-teal-500 sm:before:ml-[6.5rem] before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-0 after:w-2 after:h-2 after:bg-pink-700 after:border-4 after:box-content after:border-teal-500 after:rounded-full sm:after:ml-[6.5rem] after:-translate-x-1/2 after:translate-y-1.5">
                <p class="text-white text-xl">{i.position}</p>
                 
                </div>
                <div class="text-white opacity-75">{i.summ}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
