---
const cv = await import("../../public/cv-es.json");
const skills = cv.skills;
---
<section class="skills-section my-8">
    <h2 class="text-2xl font-bold mb-4">Skills</h2>
    <div class="flex flex-col gap-4">
      {skills.map(skill => (
        <div class="skill-category p-4 border border-gray-300 rounded">
          <h3 class="text-xl font-semibold mb-2">{skill.name}</h3>
          <div class="flex flex-wrap gap-2">
            {skill.tools.map(tool => (
              <span class="bg-gray-200 px-2 py-1 rounded">{tool}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>